# ── Server ────────────────────────────────────────────────────
PORT=5000

# ── CORS ──────────────────────────────────────────────────────
# Development: http://localhost:5173
# Production:  https://your-app.vercel.app
ALLOWED_ORIGIN=http://localhost:5173

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MINUTES=15

# ── File upload ───────────────────────────────────────────────
MAX_FILE_SIZE_MB=5

# ── OCR fallback ──────────────────────────────────────────────
OCR_TRIGGER_THRESHOLD=100

# ── AI Enhancement (optional) ─────────────────────────────────
# Leave blank to use the built-in NLP engine (free, works without a key).
# Add your API key to unlock AI-powered personalised suggestions.
AI_API_KEY=
AI_MAX_TOKENS=900
